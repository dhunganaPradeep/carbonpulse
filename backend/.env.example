# CarbonPulse backend environment (development defaults)
ENVIRONMENT=development

# Database (async SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://carbonpulse:carbonpulse@postgres:5432/carbonpulse

# Redis (rate limiting, caching, background queue)
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Postgres (used by docker-compose)
POSTGRES_USER=carbonpulse
POSTGRES_PASSWORD=carbonpulse
POSTGRES_DB=carbonpulse
